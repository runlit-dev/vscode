{
  "name": "runlit",
  "displayName": "runlit",
  "description": "AI code eval - catch hallucinated APIs and intent mismatches before you commit",
  "version": "0.0.1",
  "publisher": "runlit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/runlit-dev/vscode"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": ["Other", "Linters"],
  "keywords": ["ai", "code review", "hallucination", "eval", "cursor"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "icon": "images/icon.png",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "runlit",
          "title": "runlit",
          "icon": "images/icon.png"
        }
      ]
    },
    "views": {
      "runlit": [
        {
          "id": "runlit.findings",
          "name": "Findings"
        }
      ]
    },
    "commands": [
      {
        "command": "runlit.evalFile",
        "title": "runlit: Evaluate current file"
      },
      {
        "command": "runlit.evalSelection",
        "title": "runlit: Evaluate selection"
      },
      {
        "command": "runlit.clearDiagnostics",
        "title": "runlit: Clear diagnostics"
      },
      {
        "command": "runlit.confirmFinding",
        "title": "runlit: Confirm finding"
      },
      {
        "command": "runlit.dismissFinding",
        "title": "runlit: Dismiss finding"
      },
      {
        "command": "runlit.setApiKey",
        "title": "runlit: Set API Key"
      }
    ],
    "configuration": {
      "title": "runlit",
      "properties": {
        "runlit.apiToken": {
          "type": "string",
          "default": "",
          "markdownDescription": "Your runlit API token. Get one at [app.runlit.dev](https://app.runlit.dev) → Settings → API Keys."
        },
        "runlit.apiUrl": {
          "type": "string",
          "default": "https://api.runlit.dev",
          "description": "runlit API base URL (override for self-hosted)"
        },
        "runlit.threshold": {
          "type": "number",
          "default": 80,
          "description": "Warn if eval score falls below this value (0–100)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src",
    "package": "vsce package",
    "install-local": "npm run compile && vsce package && code --install-extension runlit-$(node -p \"require('./package.json').version\").vsix",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.96.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/vsce": "^3.0.0",
    "eslint": "^10.1.0",
    "typescript": "^5.8.0"
  }
}
